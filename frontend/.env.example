# Copy to .env.local (not committed). If set, the app calls the API at this origin (cross-origin → backend CORS must allow the UI origin).
# Leave unset for relative URLs: Vite dev proxy (vite.config.js). Docker build: pass --build-arg VITE_API_BASE_URL=...
# VITE_API_BASE_URL=http://127.0.0.1:8000
